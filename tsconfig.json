{
  "compilerOptions": {
    "outDir": "./lib",
    "rootDir": "./src",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "mocha"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"],
  "ts-node": {
    "files": true
  }
}
